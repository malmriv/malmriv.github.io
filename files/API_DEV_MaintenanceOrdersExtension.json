{
  "openapi": "3.0.3",
  "info": {
    "title": "BSM Maintenance Order Integration API (dev)",
    "description": "Integration API between the Parkare CRM and the SAP PM module in SAP S/4HANA.\nEnables lifecycle management of Maintenance Orders by updating user and system statuses\nthrough SAP Integration Suite. Due to S/4HANA's standard API constraints, the statuses are edited through the BAPI `BAPI_ALM_ORDER_MAINTAIN`.\n\n## Authentication\n\nThis API uses OAuth 2.0 authentication with the Client Credentials flow.\nTo obtain an access token, send a `POST` request to the `/oauth/token` endpoint\nusing HTTP Basic authentication (API key as username, API secret as password) and the body\n`grant_type=client_credentials` in `application/x-www-form-urlencoded` format.\n\nOnce the `access_token` is obtained, include it in every request via the `Authorization: Bearer {access_token}` header.\nAdditionally, all requests must include the `APIKey`, `APISecret` and `Accept-Encoding` headers.\n\n## Implementation notes\n\n- Integration flows do not maintain persistence. If S/4HANA returns an error, it is propagated directly to the caller.\n- The `MessageId` field is dynamically generated by SAP Integration Suite per execution. The API consumer may use it for internal logging or provide it to the integration team for troubleshooting purposes.\n- The `Details` field is always present in the response, both on success (empty array) and on error.\n- Severity codes in `Details[].Status` follow the SAP standard message convention.",
    "version": "1.0.0",
    "contact": {
      "email": "es-cci@avvale.com"
    }
  },
  "servers": [
    {
      "url": "https://bsm-apimanagement-dev-qas.test01.apimanagement.eu20.hana.ondemand.com",
      "description": "Pre-production server (DEV/QAS)"
    }
  ],
  "tags": [
    {
      "name": "authentication",
      "description": "OAuth 2.0 access token retrieval"
    },
    {
      "name": "maintenance-orders",
      "description": "Lifecycle operations on Maintenance Orders in SAP S/4HANA"
    }
  ],
  "paths": {
    "/oauth/token": {
      "post": {
        "tags": [
          "authentication"
        ],
        "summary": "Obtain an OAuth 2.0 access token",
        "description": "Endpoint to obtain a Bearer token using the OAuth 2.0 Client Credentials flow.\nCredentials (API key and API secret) are sent as HTTP Basic authentication:\n- **Username**: API key\n- **Password**: API secret\n\nThe returned `access_token` must be included in all API endpoint calls\nvia the `Authorization: Bearer {access_token}` header.",
        "operationId": "getOAuthToken",
        "servers": [
          {
            "url": "https://bsm-apimanagement-dev-qas.test01.apimanagement.eu20.hana.ondemand.com:443",
            "description": "Pre-production authentication server (QAS)"
          },
          {
            "url": "https://bsm-apimanagement-prd.prod01.apimanagement.eu20.hana.ondemand.com",
            "description": "Production authentication server (PRD)"
          }
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials"
                    ],
                    "description": "OAuth 2.0 flow type. Must always be `client_credentials`.",
                    "example": "client_credentials"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token successfully generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthTokenResponse"
                },
                "example": {
                  "refresh_token_expires_in": "0",
                  "api_product_list": "[S4HANA_MaintenanceOrder_Api]",
                  "api_product_list_json": [
                    "S4HANA_MaintenanceOrder_Api"
                  ],
                  "organization_name": "<organization_name>",
                  "developer.email": "<developer_email>",
                  "token_type": "BearerToken",
                  "issued_at": "1780062484689",
                  "client_id": "<client_id>",
                  "access_token": "<access_token>",
                  "application_name": "<application_name>",
                  "scope": "",
                  "expires_in": "44514",
                  "refresh_count": "0",
                  "status": "approved"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "ErrorCode": "error_code",
                  "Error": "Error description"
                }
              }
            }
          }
        }
      }
    },
    "/dev/ext/maintenanceorders/{orderId}/start": {
      "post": {
        "tags": [
          "maintenance-orders"
        ],
        "summary": "Set a maintenance order as as In Progress",
        "description": "Updates the **user status** of the specified Maintenance Order to **\"In Progress\"** (internally `CURS`) in SAP S/4HANA.\n\nThis endpoint is invoked by the Parkare CRM when an associated ticket transitions to *\"In Progress\"* status.\nThe relevant logic is executed through an SAP Cloud Integration flow by calling\n`BAPI_ALM_ORDER_MAINTAIN`, an SAP S/4HANA backend function.\n\nThe request requires no body.",
        "operationId": "startMaintenanceOrder",
        "parameters": [
          {
            "$ref": "#/components/parameters/orderId"
          },
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/apiSecret"
          },
          {
            "$ref": "#/components/parameters/acceptEncoding"
          },
          {
            "$ref": "#/components/parameters/authorization"
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User status successfully updated to \"In Progress\"",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "Start",
                  "Result": "Success",
                  "MessageId": "AGoYXmTiQTgJmsS_q7YFlbulmVB_",
                  "Timestamp": "2026-05-29T13:49:20.924Z",
                  "Details": [
                    {
                      "Status": "S",
                      "Message": "Order 50000004579 saved with notification: 10000004831"
                    },
                    {
                      "Status": "S",
                      "Message": "BAPI control finished"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error (e.g. incorrect URL parameters or unrecognised action)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderErrorResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "Unknown",
                  "Result": "Failure",
                  "MessageId": "AGoYXmTiQTgJmsS_q7YFlbulmVB_",
                  "Timestamp": "2026-05-29T13:49:20.924Z",
                  "Details": [
                    {
                      "Status": "E",
                      "Message": "The action {action} is not defined."
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorised. Access token missing, invalid or expired.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Error during modification in SAP S/4HANA or internal error in the integration layer.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderErrorResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "Start",
                  "Result": "Failure",
                  "MessageId": "AGoYXmTiQTgJmsS_q7YFlbulmVB_",
                  "Timestamp": "2026-05-29T13:49:20.924Z",
                  "Details": [
                    {
                      "Status": "E",
                      "Message": "First error returned by S/4HANA"
                    },
                    {
                      "Status": "E",
                      "Message": "Second error returned by S/4HANA"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/dev/ext/maintenanceorders/{orderId}/close": {
      "post": {
        "tags": [
          "maintenance-orders"
        ],
        "summary": "Technically close a maintenance order",
        "description": "Updates the **system status** of the specified Maintenance Order to **technical completion** (internally `CTEC`) in SAP S/4HANA.\n\nThis endpoint is invoked by the Parkare CRM when an associated ticket transitions to *\"Closed\"* status.\nThe relevant logic is executed through an SAP Cloud Integration flow by calling\n`BAPI_ALM_ORDER_MAINTAIN`, an SAP S/4HANA backend function.\n\nThe request requires no body.",
        "operationId": "closeMaintenanceOrder",
        "parameters": [
          {
            "$ref": "#/components/parameters/orderId"
          },
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/apiSecret"
          },
          {
            "$ref": "#/components/parameters/acceptEncoding"
          },
          {
            "$ref": "#/components/parameters/authorization"
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "System status successfully updated to technical completion (CTEC)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "Close",
                  "Result": "Success",
                  "MessageId": "BHpZYnUjRUhKntT_r8ZGmcvnWCI_",
                  "Timestamp": "2026-05-29T14:02:11.310Z",
                  "Details": [
                    {
                      "Status": "S",
                      "Message": "Order 50000004579 saved with notification: 10000004831"
                    },
                    {
                      "Status": "S",
                      "Message": "BAPI control finished"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error (e.g. incorrect URL parameters or unrecognised action)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderErrorResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "Unknown",
                  "Result": "Failure",
                  "MessageId": "BHpZYnUjRUhKntT_r8ZGmcvnWCI_",
                  "Timestamp": "2026-05-29T14:02:11.310Z",
                  "Details": [
                    {
                      "Status": "E",
                      "Message": "The action {action} is not defined."
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorised. Access token missing, invalid or expired.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Error during modification in SAP S/4HANA or internal error in the integration layer.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderErrorResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "Close",
                  "Result": "Failure",
                  "MessageId": "BHpZYnUjRUhKntT_r8ZGmcvnWCI_",
                  "Timestamp": "2026-05-29T14:02:11.310Z",
                  "Details": [
                    {
                      "Status": "E",
                      "Message": "First error returned by S/4HANA"
                    },
                    {
                      "Status": "E",
                      "Message": "Second error returned by S/4HANA"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/dev/ext/maintenanceorders/{orderId}/pendingvalidation": {
      "post": {
        "tags": [
          "maintenance-orders"
        ],
        "summary": "Set a maintenance order as Pending Validation",
        "description": "Updates the **user status** of the specified Maintenance Order to **\"Pending Validation by BSM\"** (internally `VBSM`) in SAP S/4HANA.\n\nThis endpoint is invoked by the Parkare CRM when an external provider closes an associated ticket, signalling that the work has been completed and the order is awaiting validation by BSM.\nThe relevant logic is executed through an SAP Cloud Integration flow by calling\n`BAPI_ALM_ORDER_MAINTAIN`, an SAP S/4HANA backend function.\n\nThe request requires no body.",
        "operationId": "pendingValidationMaintenanceOrder",
        "parameters": [
          {
            "$ref": "#/components/parameters/orderId"
          },
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/apiSecret"
          },
          {
            "$ref": "#/components/parameters/acceptEncoding"
          },
          {
            "$ref": "#/components/parameters/authorization"
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User status successfully updated to \"Pending Validation by BSM\" (VBSM)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "PendingValidation",
                  "Result": "Success",
                  "MessageId": "CIqAZoVkSViLouU_s9AHndwoXDJ_",
                  "Timestamp": "2026-05-29T14:15:33.210Z",
                  "Details": [
                    {
                      "Status": "S",
                      "Message": "Order 50000004579 saved with notification: 10000004831"
                    },
                    {
                      "Status": "S",
                      "Message": "BAPI control finished"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error (e.g. incorrect URL parameters or unrecognised action)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderErrorResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "Unknown",
                  "Result": "Failure",
                  "MessageId": "CIqAZoVkSViLouU_s9AHndwoXDJ_",
                  "Timestamp": "2026-05-29T14:15:33.210Z",
                  "Details": [
                    {
                      "Status": "E",
                      "Message": "The action {action} is not defined."
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorised. Access token missing, invalid or expired.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Error during modification in SAP S/4HANA or internal error in the integration layer.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceOrderErrorResponse"
                },
                "example": {
                  "MaintenanceOrder": "50000004579",
                  "Action": "PendingValidation",
                  "Result": "Failure",
                  "MessageId": "CIqAZoVkSViLouU_s9AHndwoXDJ_",
                  "Timestamp": "2026-05-29T14:15:33.210Z",
                  "Details": [
                    {
                      "Status": "E",
                      "Message": "First error returned by S/4HANA"
                    },
                    {
                      "Status": "E",
                      "Message": "Second error returned by S/4HANA"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "orderId": {
        "name": "orderId",
        "in": "path",
        "required": true,
        "description": "Maintenance Order identifier in SAP S/4HANA (internal field `MaintenanceOrder`).\nThe caller must already know the identifier of the order to be managed.",
        "schema": {
          "type": "string"
        },
        "example": "50000004579"
      },
      "apiKey": {
        "name": "APIKey",
        "in": "header",
        "required": true,
        "description": "Access API key provided by the platform administrator.",
        "schema": {
          "type": "string"
        },
        "example": "<api_key>"
      },
      "apiSecret": {
        "name": "APISecret",
        "in": "header",
        "required": true,
        "description": "API secret associated with the API key.",
        "schema": {
          "type": "string"
        },
        "example": "<api_secret>"
      },
      "acceptEncoding": {
        "name": "Accept-Encoding",
        "in": "header",
        "required": true,
        "description": "Compression encodings accepted by the client.",
        "schema": {
          "type": "string"
        },
        "example": "deflate, gzip"
      },
      "authorization": {
        "name": "Authorization",
        "in": "header",
        "required": true,
        "description": "Bearer token obtained from the `/oauth/token` endpoint.",
        "schema": {
          "type": "string"
        },
        "example": "Bearer mWqc7J7gplqjCM43SFCjwmGYbUmT"
      }
    },
    "schemas": {
      "OAuthTokenResponse": {
        "type": "object",
        "description": "Authentication server response containing the OAuth 2.0 access token.",
        "properties": {
          "refresh_token_expires_in": {
            "type": "string",
            "description": "Refresh token expiry time in seconds. A value of \"0\" indicates it does not apply."
          },
          "api_product_list": {
            "type": "string",
            "description": "List of API products the token has access to, as a string."
          },
          "api_product_list_json": {
            "type": "array",
            "description": "List of API products the token has access to, as an array.",
            "items": {
              "type": "string"
            }
          },
          "organization_name": {
            "type": "string",
            "description": "Internal organisation name in SAP API Management."
          },
          "developer.email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the developer associated with the application."
          },
          "token_type": {
            "type": "string",
            "description": "Type of token issued.",
            "example": "BearerToken"
          },
          "issued_at": {
            "type": "string",
            "description": "Token issuance timestamp in milliseconds epoch."
          },
          "client_id": {
            "type": "string",
            "description": "OAuth client identifier."
          },
          "access_token": {
            "type": "string",
            "description": "Bearer access token. Must be included in the `Authorization` header of all API requests."
          },
          "application_name": {
            "type": "string",
            "description": "UUID identifier of the application registered in SAP API Management."
          },
          "scope": {
            "type": "string",
            "description": "Scopes granted to the token. Empty if no specific scopes have been defined."
          },
          "expires_in": {
            "type": "string",
            "description": "Access token expiry time in seconds."
          },
          "refresh_count": {
            "type": "string",
            "description": "Number of times the token has been refreshed."
          },
          "status": {
            "type": "string",
            "description": "Status of the issued token.",
            "example": "approved"
          }
        }
      },
      "MaintenanceOrderDetail": {
        "type": "object",
        "description": "Individual detail message returned by SAP S/4HANA.",
        "required": [
          "Status",
          "Message"
        ],
        "properties": {
          "Status": {
            "type": "string",
            "description": "Message severity code following the SAP standard convention:\n- `S` — Success\n- `I` — Information\n- `W` — Warning\n- `E` — Error\n- `A` — Abort (critical error, terminates the process)",
            "enum": [
              "S",
              "I",
              "W",
              "E",
              "A"
            ],
            "example": "E"
          },
          "Message": {
            "type": "string",
            "description": "Descriptive text of the message returned by S/4HANA or generated by the integration flow.",
            "example": "Order 50000004579 cannot be set to TECO: missing confirmation."
          }
        }
      },
      "MaintenanceOrderResponse": {
        "type": "object",
        "description": "Standard API response for a successfully completed operation.",
        "required": [
          "MaintenanceOrder",
          "Action",
          "Result",
          "MessageId",
          "Timestamp",
          "Details"
        ],
        "properties": {
          "MaintenanceOrder": {
            "type": "string",
            "description": "Identifier of the processed Maintenance Order.",
            "example": "50000004579"
          },
          "Action": {
            "type": "string",
            "description": "Action executed on the Maintenance Order.",
            "enum": [
              "Start",
              "Close",
              "PendingValidation"
            ],
            "example": "Start"
          },
          "Result": {
            "type": "string",
            "description": "Operation result.",
            "enum": [
              "Success"
            ],
            "example": "Success"
          },
          "MessageId": {
            "type": "string",
            "description": "Unique message identifier generated by SAP Integration Suite for this execution.",
            "example": "AGoYXmTiQTgJmsS_q7YFlbulmVB_"
          },
          "Timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Request processing date and time in ISO 8601 UTC format.",
            "example": "2026-05-29T13:49:20.924Z"
          },
          "Details": {
            "type": "array",
            "description": "Array of detail messages. Always present; may be empty on success, but S/4HANA usually returns some confirmation.",
            "items": {
              "$ref": "#/components/schemas/MaintenanceOrderDetail"
            },
            "example": []
          }
        }
      },
      "MaintenanceOrderErrorResponse": {
        "type": "object",
        "description": "Standard API response for a validation error (HTTP 400) or an S/4HANA processing error (HTTP 500).",
        "required": [
          "MaintenanceOrder",
          "Action",
          "Result",
          "MessageId",
          "Timestamp",
          "Details"
        ],
        "properties": {
          "MaintenanceOrder": {
            "type": "string",
            "description": "Identifier of the processed Maintenance Order.",
            "example": "50000004579"
          },
          "Action": {
            "type": "string",
            "description": "Action that was attempted on the Maintenance Order.",
            "enum": [
              "Start",
              "Close",
              "PendingValidation",
              "Unknown"
            ],
            "example": "Start"
          },
          "Result": {
            "type": "string",
            "description": "Operation result.",
            "enum": [
              "Failure"
            ],
            "example": "Failure"
          },
          "MessageId": {
            "type": "string",
            "description": "Unique message identifier generated by SAP Integration Suite for this execution.",
            "example": "AGoYXmTiQTgJmsS_q7YFlbulmVB_"
          },
          "Timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Request processing date and time in ISO 8601 UTC format.",
            "example": "2026-05-29T13:49:20.924Z"
          },
          "Details": {
            "type": "array",
            "description": "Array of detail messages containing errors returned by S/4HANA or generated by the integration flow.",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/MaintenanceOrderDetail"
            },
            "example": [
              {
                "Status": "E",
                "Message": "First error returned by S/4HANA"
              }
            ]
          }
        }
      },
      "Error": {
        "type": "object",
        "description": "Generic platform error (e.g. authentication failure).",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code.",
            "example": "401"
          },
          "message": {
            "type": "string",
            "description": "Error description.",
            "example": "Unauthorized"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained from the `/oauth/token` endpoint. Include in the header:\n`Authorization: Bearer {access_token}`"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication used exclusively for the `/oauth/token` endpoint.\n- **Username**: API key provided by the administrator\n- **Password**: Associated API secret"
      }
    }
  }
}